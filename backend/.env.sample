# Server Configuration
PORT=8000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Database Connection
# Replace with your actual MongoDB URI. Do not include the database name in this string!
# The database name (e.g., videotube) is strictly managed inside src/constants.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net

# Security & Authentications
ACCESS_TOKEN_SECRET=your_long_random_secret_string_here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_another_long_random_secret_string_here
REFRESH_TOKEN_EXPIRY=10d

# Media Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
